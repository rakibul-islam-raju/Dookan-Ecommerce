NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_BASE_APP_URL=http://localhost:8000
# Internal API URL used by Next.js server code inside Docker/Compose.
# Browser requests still use NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=http://localhost:8000/api/v1

# Auth
NEXT_PUBLIC_AUTH_COOKIE_NAME=access_token
NEXT_PUBLIC_REFRESH_COOKIE_NAME=refresh_token
# Set to "true" only if frontend is served over HTTPS
# Keep as "false" or unset for HTTP (including HTTP in production)
NEXT_PUBLIC_COOKIE_SECURE=false

# ISR revalidation time
REVALIDATE_PRODUCTS=7200 # 2 hours
REVALIDATE_CATEGORIES=7200 # 2 hours

ON_HTTPS=false

# On-demand Next.js revalidation (called from admin)
REVALIDATE_SECRET=change-me
REVALIDATE_ALLOWED_ORIGINS=http://localhost:5173
