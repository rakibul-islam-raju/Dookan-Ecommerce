# Django
# Avoid raw `$` characters in Docker Compose env values unless you escape them as `$$`.
DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=api.example.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://api.example.com,https://shop.example.com,https://admin.example.com
ADMIN_URL=https://admin.example.com
FRONTEND_URL=https://shop.example.com

# Meta / Facebook OAuth for automatic Pixel ID discovery in admin.
# CAPI access tokens are still configured manually in Site Settings.
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URL=https://admin.example.com/store/settings/meta/callback
META_OAUTH_SCOPES=ads_management,business_management

# Database
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=https://shop.example.com,https://admin.example.com

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-smtp-user@example.com
EMAIL_HOST_PASSWORD=replace-with-your-smtp-app-password
DEFAULT_FROM_EMAIL=Dookan <noreply@example.com>

# OTP
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6

# Cache and DRF throttling
CACHE_DIR=/tmp/django-cache
CACHE_TIMEOUT=300
CACHE_MAX_ENTRIES=1000
DRF_THROTTLE_ANON=120/hour
DRF_THROTTLE_USER=1000/hour
DRF_THROTTLE_AUTH_LOGIN=5/minute
DRF_THROTTLE_AUTH_REGISTER=5/hour
DRF_THROTTLE_AUTH_REFRESH=30/minute
DRF_THROTTLE_AUTH_LOGOUT=60/hour
DRF_THROTTLE_AUTH_VERIFY_EMAIL=10/hour
DRF_THROTTLE_AUTH_RESEND_VERIFICATION=5/hour
DRF_THROTTLE_AUTH_PASSWORD_RESET=5/hour
DRF_THROTTLE_AUTH_PASSWORD_RESET_CONFIRM=10/hour

# Django HTTPS / proxy security
USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY

# Gunicorn
RUN_MIGRATIONS=1
COLLECT_STATIC=1
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60

# Nginx reverse proxy / rate limiting
NGINX_SERVER_NAME=api.example.com
NGINX_SSL_CERTIFICATE=/etc/nginx/certs/fullchain.pem
NGINX_SSL_CERTIFICATE_KEY=/etc/nginx/certs/privkey.pem
NGINX_BACKEND_UPSTREAM=api:8000
NGINX_CLIENT_MAX_BODY_SIZE=20m
NGINX_RATE_LIMIT_GENERAL=30r/s
NGINX_RATE_LIMIT_GENERAL_BURST=60
NGINX_RATE_LIMIT_AUTH=10r/m
NGINX_RATE_LIMIT_AUTH_BURST=20
